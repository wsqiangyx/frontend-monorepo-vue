# 芋道管理系统 环境变量
# 复制本文件为 .env.development 或 .env.production

# ============================================================
# 运行模式说明
# ============================================================
# 1. 纯 Mock 模式（默认）：不配置 VITE_PROXY_TARGET，所有请求走 mock
# 2. 纯后端模式：VITE_ENABLE_MSW=false，配置 VITE_PROXY_TARGET
# 3. 混合模式：VITE_ENABLE_MSW=true，配置 VITE_PROXY_TARGET
#    → 有 mock handler 的接口走 mock，其余透传到后端

# 应用标题
VITE_APP_TITLE=芋道管理系统

# 是否启用 MSW Mock（默认 true）
VITE_ENABLE_MSW=true

# API 基础路径（与 mock handlers 路径前缀一致）
VITE_API_BASE_URL=/api

# Vite 代理目标地址（可选，对接真实后端时取消注释）
# VITE_PROXY_TARGET=http://localhost:48080
