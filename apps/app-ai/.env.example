# .env 文件（存储敏感信息，不要提交到 Git）

# OpenAI API Key（从 https://platform.openai.com/api-keys 获取）
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key（可选，如果使用 Claude 模型）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 千问 API KEY
QIANWEN_API_KEY=sk-your-qwen-api-key
# 千问调用的兼容调用地址
API_URL=http://39.105.13.235:3000/v1

# LangSmith 配置（可选，但强烈推荐用于调试）
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=sk-your-langsmith-api-key-here
LANGSMITH_PROJECT=vue3-app-ai
