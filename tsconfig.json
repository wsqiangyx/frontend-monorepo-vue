// ============================================================================
// tsconfig.json — 根目录 TypeScript 配置
// ============================================================================
// 此文件仅供 IDE 集成和根目录类型检查使用，不直接参与任何包的编译产出。
// 根目录不是编译单元：
//   - files: [] 明确声明无源文件
//   - noEmit: true 禁止输出文件
// 各 workspace 有独立的 tsconfig.json，通过 extends 继承 tsconfig.base.json。
// ============================================================================
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // 根目录不产出任何编译结果，仅用于 IDE 类型服务和根级类型检查。
    "noEmit": true
  }
}
