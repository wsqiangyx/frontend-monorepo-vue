{
  "name": "@repo/shared-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true});rmSync('tsconfig.build.tsbuildinfo',{force:true});\" && vue-tsc --noEmit && node ../../scripts/vite.cjs build && vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json --outDir dist",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "node ../../scripts/vitest.cjs run",
    "test:watch": "node ../../scripts/vitest.cjs",
    "test:coverage": "node ../../scripts/vitest.cjs run --coverage"
  },
  "dependencies": {
    "@antv/g2": "catalog:",
    "@repo/design-tokens": "workspace:*",
    "@repo/shared-i18n": "workspace:*",
    "@repo/shared-service": "workspace:*",
    "@repo/shared-utils": "workspace:*",
    "tdesign-vue-next": "catalog:"
  },
  "peerDependencies": {
    "vue": "catalog:"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.2.4",
    "vite": "8.0.10"
  }
}
