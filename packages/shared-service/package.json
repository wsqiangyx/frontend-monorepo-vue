{
  "name": "@repo/shared-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "default": "./dist/permissions/index.js"
    },
    "./mock": {
      "types": "./dist/mock/index.d.ts",
      "default": "./dist/mock/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true});rmSync('tsconfig.build.tsbuildinfo',{force:true});\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node ../../scripts/vitest.cjs run",
    "test:watch": "node ../../scripts/vitest.cjs",
    "test:coverage": "node ../../scripts/vitest.cjs run --coverage"
  },
  "dependencies": {
    "@repo/shared-utils": "workspace:*",
    "axios": "catalog:",
    "msw": "catalog:"
  }
}
